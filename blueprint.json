{
  "landingPage": "/wp-admin/",
  "preferredVersions": {
    "php": "8.3"
  },
  "steps": [
    
    {
      "step": "defineWpConfigConsts",
      "consts": {
        "WP_DEBUG": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "local",
        "path": "."
      }
    },
    {
      "step": "activatePlugin",
