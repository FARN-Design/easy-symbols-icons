{
  "landingPage": "/wp-admin/admin.php?page=eics_settings-page&tab=general",
  "features": {
    "networking": true
  },
  "preferredVersions": {
    "php": "8.4",
    "wp": "latest"
  },
  "phpExtensionBundles": [
    "kitchen-sink"
  ],
  "login": true,
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "easy-symbols-icons"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "runPHP",
      "code": "<?php $base='wp-content/uploads'; if(!is_dir($base)){mkdir($base,0777,true);} $dir=$base.'/eics-icons'; if(!is_dir($dir)){mkdir($dir);} $dir2=$dir.'/dashicons'; if(!is_dir($dir2)){mkdir($dir2);} $url='https://s.w.org/wp-includes/fonts/dashicons.ttf'; $data=file_get_contents($url); if($data!==false){file_put_contents($dir2.'/dashicons.ttf',$data);} ?>"
    },
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    }
  ]
}